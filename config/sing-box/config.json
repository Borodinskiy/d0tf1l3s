{ // Default settings should be at least compatible with linux, android and windows
  "log": {
    "level": "warn",
    "timestamp": true
  },
  "dns": {
    "final": "dns-remote",
    "strategy": "ipv4_only",
    "disable_cache": false,
    "disable_expire": false,
    "independent_cache": false,
    "servers": [
      {
        "tag": "dns-direct",
        "type": "h3",
        "server": "1.1.1.1"
      },
      {
        "tag": "dns-remote",
        "type": "h3",
        "server": "1.1.1.1"
      }
    ]
  },
  "route": {
    "auto_detect_interface": true,
    // Non matched traffic bypasses proxy
    "final": "out-direct",
    "default_domain_resolver": {
      "server": "dns-direct",
      "strategy": "ipv4_only"
    },
    "rules": [
      { // For dns redirect
        "action": "sniff"
      },
      {
        "protocol": "dns",
        "action": "hijack-dns"
      },
      { // Yes
        "protocol": "bittorrent",
        "outbound": "out-direct"
      },
      { // No tunneling conflicts
        "inbound": "in-tun",
        "process_name": [
          "xray",
          "xray.exe",
          "wireproxy",
          "wireproxy.exe"
        ],
        "outbound": "out-direct"
      },
      { // Some web sites hate proxy
        "domain_suffix": [
          "reddit.com",
          "www.reddit.com",
          "reddit.map.fastly.net",
          "embed.reddit.com",
          "redditmedia.com",
          "redditstatic.com",
          "rlcdn.com",
          // Speedup downloading
          "download.minecraft.net",
          "mirror.team-host.ru"
        ],
        "outbound": "out-direct"
      },
      { // All traffic that comes into proxy server... Will be sent to remote
        "inbound": "in-proxy",
        "outbound": "out-remote"
      },
      { // Force remote for domains
        "domain_suffix": [
          "7tv.app",
          "7tv.io",
          "betterttv.net",
          "cloudflare-ech.com",
          "dis.gd",
          "discord-activities.com",
          "discord-attachments-uploads-prd.storage.googleapis.com",
          "discord.app",
          "discord.co",
          "discord.com",
          "discord.design",
          "discord.dev",
          "discord.gg",
          "discord.gift",
          "discord.gifts",
          "discord.media",
          "discord.new",
          "discord.status",
          "discord.store",
          "discordactivities.com",
          "discordapp.com",
          "discordapp.net",
          "discordcdn.com",
          "discordmerch.com",
          "discordpartygames.com",
          "discordsays.com",
          "discordsez.com",
          "ffzap.com",
          "frankerfacez.com",
          "googlevideo.com",
          "jnn-pa.googleapis.com",
          "stable.dl2.discordapp.net",
          "wide-youtube.l.google.com",
          "youtu.be",
          "youtube-nocookie.com",
          "youtube-ui.l.google.com",
          "youtube.com",
          "youtubeembeddedplayer.googleapis.com",
          "youtubei.googleapis.com",
          "youtubekids.com",
          "yt-video-upload.l.google.com",
          "yt3.ggpht.com",
          "yt3.googleusercontent.com",
          "yt4.ggpht.com",
          "ytimg.com",
          "ytimg.l.google.com",
          "download.nvidia.com",
          "ciscobinary.openh264.org",
          "dl.flathub.org",
          "deb.sagernet.org",
          "download.vscodium.com",
          "golang.org",
          "files.holarse-linuxgaming.de"
        ],
        "outbound": "out-remote"
      },
      { // Android apps
        "package_name": [
          "app.revanced.android.youtube",
          "com.google.android.youtube",
          "org.mozilla.fennec_fdroid",
          "com.aurora.store",
          "com.discord"
        ],
        "outbound": "out-remote"
      },
      { // OS processes
        "inbound": "in-tun",
        "process_name": [
          "Discord.exe",
          ".Discord-wrappe",
          ".Discord-wrapped",
          "/app/discord/Discord",
          "com.discordapp.Discord",
          "Discord",
          "songrec.exe",
          "songrec",
          "librewolf.exe",
          "librewolf",
          "telegram.exe",
          "Telegram",
          "steam.exe",
          "steamwebhelper.exe",
          "streaming_client.exe",
          "SteamService.exe",
          "steam",
          "steamwebhelper",
          "streaming_client",
          "SteamService"
        ],
        "outbound": "out-remote"
      }
    ]
  }
}
