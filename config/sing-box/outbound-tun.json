{
  "inbounds": [
    { // For redirecting some packets to remote outbound
      "type": "tun",
      "tag": "in-tun",
      "interface_name": "singing_tun",
      "mtu": 9000,
      "address": [
        "172.16.0.1/30"
        //"fd00::1/126"
      ],
      "auto_route": true,
      "auto_redirect": true,
      "strict_route": true,
      "stack": "gvisor",
      "endpoint_independent_nat": false
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "out-direct",
      "bind_interface": "awg0"
    },
    {
      "type": "direct",
      "tag": "out-remote",
      "bind_interface": "wlp1s0",
      "domain_resolver": "dns-remote"
    }
  ]
}